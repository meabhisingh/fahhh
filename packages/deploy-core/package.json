{
	"name": "@fahhh/deploy-core",
	"private": false,
	"type": "module",
	"version": "0.1.0",
	"engines": {
		"node": ">=18"
	},
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "tsup --watch",
		"build": "tsup && tsc --emitDeclarationOnly",
		"check-types": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"clean": "rm -rf .turbo dist node_modules"
	},
	"devDependencies": {
		"@fahhh/typescript-config": "workspace:*",
		"@types/node": "^22.15.3",
		"tsup": "^8.5.1"
	}
}
