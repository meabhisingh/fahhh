{
	"name": "fahhh",
	"description": "The official Fahhh framework package",
	"license": "MIT",
	"type": "module",
	"version": "0.1.0",
	"engines": {
		"node": ">=18"
	},
	"types": "./dist/index.d.ts",
	"main": "./dist/index.js",
	"bin": {
		"fahhh": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/meabhisingh/fahhh"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"dev": "tsup --watch",
		"build": "tsup && tsc --emitDeclarationOnly",
		"check-types": "tsc --noEmit",
		"prepublishOnly": "pnpm build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"clean": "rm -rf .turbo dist node_modules"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@fahhh/deploy-core": "workspace:*",
		"@fahhh/runtime": "workspace:*",
		"jiti": "^2.4.2"
	},
	"peerDependencies": {
		"vite": ">=5"
	},
	"devDependencies": {
		"@fahhh/compiler": "workspace:*",
		"@fahhh/vite-plugin": "workspace:*",
		"@fahhh/typescript-config": "workspace:*",
		"@types/node": "^22.15.3",
		"tsup": "^8.5.1"
	}
}
